# Secrets et configuration locale
.env
.env.local
.env.*.local
*.env

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build
dist/
build/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Cache
.cache/
.pytest_cache/

# Fichiers temporaires Office
~$*

# Livrables generes (lourds, regenerables via les scripts generate_*.py)
*.docx
*.xlsx
*.pptx
*.pdf
*.ipynb

# Exceptions : on garde les fichiers de documentation
!HANDOVER.md
!CLAUDE.md
!README.md
